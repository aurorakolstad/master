$OFFLISTING

* MPS/GE MODEL GENERATOR FILE

$OFFINLINE
$INLINECOM { }
PUT   MPS,'$MODEL:ARROW_DEBREU'/;

{    2}  PUT /;
 
{    2}  PUT'$SECTORS:'/;
{    4}  LOOP((CNT,HH),
{    4}    PUT /,'U''.'CNT.TL'.'HH.TL;
{    4}  );
