{   10}  LOOP((CNT,SEC)$(XDZ(CNT,SEC) AND NOT SAMEAS(SEC,"IH2S") AND NOT SAMEAS(SEC,"IH2C")  AND NOT SAMEAS(SEC,"IH2E") AND NOT SAMEAS(SEC,"IELC")),
